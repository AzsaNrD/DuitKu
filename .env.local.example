# Neon Postgres connection string (dari dashboard neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth — generate dengan: npx auth secret  (atau openssl rand -base64 32)
AUTH_SECRET="ganti-dengan-secret-acak"

# Google OAuth (dari console.cloud.google.com — boleh dikosongkan jika belum pakai login Google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
